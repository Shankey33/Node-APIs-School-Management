{
  "info": {
    "name": "School Management API",
    "description": "Postman collection with multiple test cases for the School Management API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Health Check",
      "item": [
        {
          "name": "Get Server Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Success flag is true\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.message).to.eql(\"API is running\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Add School",
      "item": [
        {
          "name": "Add School - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Returns success true with inserted data\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data).to.have.property(\"id\");",
                  "    pm.expect(jsonData.data.name).to.include(\"Delhi Public School\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Delhi Public School {{$randomUUID}}\",\n  \"address\": \"Mathura Road, New Delhi, India\",\n  \"latitude\": 28.5494,\n  \"longitude\": 77.2663\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/addSchool",
              "host": ["{{baseUrl}}"],
              "path": ["addSchool"]
            }
          }
        },
        {
          "name": "Add School - Validation Failure (Missed Fields)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 422 - Unprocessable Entity\", function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "pm.test(\"Returns validation errors\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(false);",
                  "    pm.expect(jsonData.errors).to.be.an(\"array\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Short\",\n  \"latitude\": 28.5494\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/addSchool",
              "host": ["{{baseUrl}}"],
              "path": ["addSchool"]
            }
          }
        },
        {
          "name": "Add School - Validation Failure (Invalid Coordinates)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 422\", function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "pm.test(\"Checks coordinate boundaries\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(false);",
                  "    var errorFields = jsonData.errors.map(e => e.field);",
                  "    pm.expect(errorFields).to.include(\"latitude\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test School Invalid Geo\",\n  \"address\": \"A Random Address Street\",\n  \"latitude\": 105.0000,\n  \"longitude\": -86.1581\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/addSchool",
              "host": ["{{baseUrl}}"],
              "path": ["addSchool"]
            }
          }
        }
      ]
    },
    {
      "name": "3. List Schools",
      "item": [
        {
          "name": "List Schools - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Returns list of schools\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"Schools include distance_km\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 0) {",
                  "        pm.expect(jsonData.data[0]).to.have.property(\"distance_km\");",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/listSchools?latitude=28.6139&longitude=77.2090",
              "host": ["{{baseUrl}}"],
              "path": ["listSchools"],
              "query": [
                { "key": "latitude", "value": "28.6139" },
                { "key": "longitude", "value": "77.2090" }
              ]
            }
          }
        },
        {
          "name": "List Schools - Validation Failure (Missing Params)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 422 - Unprocessable Entity\", function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "pm.test(\"Validates missing parameters\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(false);",
                  "    pm.expect(jsonData.errors).to.be.an(\"array\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/listSchools?latitude=28.6139",
              "host": ["{{baseUrl}}"],
              "path": ["listSchools"],
              "query": [
                { "key": "latitude", "value": "28.6139" }
              ]
            }
          }
        },
        {
          "name": "List Schools - Invalid Coordinate Value",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 422\", function () {",
                  "    pm.response.to.have.status(422);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/listSchools?latitude=abc&longitude=xyz",
              "host": ["{{baseUrl}}"],
              "path": ["listSchools"],
              "query": [
                { "key": "latitude", "value": "abc" },
                { "key": "longitude", "value": "xyz" }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://school-management-api-qa2q.onrender.com",
      "type": "string"
    }
  ]
}